file_name = "course_outcomes.txt"

with open(file_name, "w") as file:
  file.write("Course Outcomes (COs):\n")
  file.write("1. Understand the basics of python programming.\n")
  file.write("2. Apply loops, function, and data structure.\n")
  file.write("3. Handle file and perform basic I/O operation.\n")
  file.write("4. slove programming program using logic and alogorithms.\n")
  file.write("5. Develop small projects using python.\n")

print(f"Data weitten to (file_name) successfully.\n")

print("Reading file content:")
with open(file_name, "r") as file:
  content = file.read()
  print(content)


with open(file_name,"a") as file:
 file.write("6. Gain understanding of basic software development practices.\n")

print("After appending a new course outcome:")
with open(file_name, "r") as file:
    print(file.readlines())
    
with open(file_name, "r") as file:
          lines = file.readlines()
          print("Number of course outcomes (lines):", len(lines) - 1) 
  
